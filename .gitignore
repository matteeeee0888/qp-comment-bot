node_modules/
*.log
.DS_Store
# state/ IS committed (post records + page-topic-map travel across machines).
# Images are ephemeral and must NOT be committed:
state/img/
state/work/
# Transient per-run summary (regenerated by publish.js each run) — not durable archive:
state/last-run.json
# Local secrets live outside the repo (~/.claude/credentials) — never commit any here:
*.env
